---
import BaseLayout from "./BaseLayout.astro";
import CommentSection from "@components/CommentSection.astro";
import TagList from "@components/TagList.astro";
import { formatDate } from "@utils/date-format";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  readingTime?: string;
  slug: string;
}

const { title, description, pubDate, updatedDate, heroImage, tags, readingTime, slug } = Astro.props;
---

<BaseLayout title={title} description={description} image={heroImage} article>
  <article class="content-container blog-post">
    <header class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {readingTime && (
          <>
            <span class="separator">&middot;</span>
            <span>{readingTime}</span>
          </>
        )}
      </div>
      {updatedDate && (
        <p class="updated-date">
          Updated on <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
        </p>
      )}
      {tags && tags.length > 0 && (
        <div class="post-tags">
          <TagList tags={tags} />
        </div>
      )}
    </header>

    {heroImage && (
      <div class="hero-image">
        <img src={heroImage} alt={title} width="720" height="405" loading="eager" />
      </div>
    )}

    <div class="prose">
      <slot />
    </div>

    <CommentSection postId={slug} />
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding: 2rem 1.5rem 4rem;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-header h1 {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    color: var(--color-muted);
  }

  .updated-date {
    font-size: 0.8125rem;
    color: var(--color-muted);
    font-style: italic;
    margin-top: 0.25rem;
  }

  .post-tags {
    margin-top: 0.75rem;
  }

  .hero-image {
    margin-bottom: 2rem;
    border-radius: var(--radius);
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    border-radius: var(--radius);
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 1.75rem;
    }

    .blog-post {
      padding: 1.5rem 1rem 3rem;
    }
  }
</style>
