---
interface Props {
  tags: string[];
  activeTag?: string;
}

const { tags, activeTag } = Astro.props;
---

<div class="tag-list">
  {tags.map((tag) => (
    <a
      href={`/tags/${tag}`}
      class:list={["tag-chip", { active: tag === activeTag }]}
    >
      #{tag}
    </a>
  ))}
</div>

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-chip {
    font-size: 0.8125rem;
    padding: 0.35em 0.75em;
    border-radius: 20px;
    background: var(--color-subtle-bg);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    transition: all var(--transition);
  }

  .tag-chip:hover,
  .tag-chip.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
</style>
