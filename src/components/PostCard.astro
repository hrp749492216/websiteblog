---
import { formatDate } from "@utils/date-format";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
  readingTime?: string;
  tags?: string[];
  slug: string;
}

const { title, description, pubDate, heroImage, readingTime, tags, slug } = Astro.props;
---

<article class="post-card">
  <a href={`/blog/${slug}`} class="card-link">
    {heroImage && (
      <div class="card-image">
        <img src={heroImage} alt={title} loading="lazy" />
      </div>
    )}
    <div class="card-content">
      <h3 class="card-title">{title}</h3>
      <div class="card-meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {readingTime && <span class="separator">&middot;</span>}
        {readingTime && <span>{readingTime}</span>}
      </div>
      <p class="card-excerpt">{description}</p>
      {tags && tags.length > 0 && (
        <div class="card-tags">
          {tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>

<style>
  .post-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(61, 50, 41, 0.08);
  }

  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .post-card:hover .card-image img {
    transform: scale(1.03);
  }

  .card-content {
    padding: 1.25rem;
  }

  .card-title {
    font-size: 1.175rem;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .card-excerpt {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--color-accent);
    background: var(--color-subtle-bg);
    padding: 0.15em 0.5em;
    border-radius: 4px;
  }
</style>
