---
import { getCollection } from "astro:content";
import Hero from "@components/Hero.astro";
import PostCard from "@components/PostCard.astro";
import PostGrid from "@components/PostGrid.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

const allPosts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPosts = allPosts.filter((p) => p.data.featured);
const recentPosts = allPosts.slice(0, 6);
---

<BaseLayout title="Home" description="Personal blog of Hari Raman Pokhrel — thoughts, ideas, and things I'm learning.">
  <div class="container">
    <Hero />

    {featuredPosts.length > 0 && (
      <section class="section">
        <h2 class="section-title">Featured</h2>
        <PostGrid>
          {featuredPosts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              heroImage={post.data.heroImage}
              readingTime={post.data.readingTime}
              tags={post.data.tags}
              slug={post.id}
            />
          ))}
        </PostGrid>
      </section>
    )}

    <section class="section">
      <div class="section-header">
        <h2 class="section-title">Recent Posts</h2>
        <a href="/blog" class="view-all">View all &rarr;</a>
      </div>
      <PostGrid>
        {recentPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            heroImage={post.data.heroImage}
            readingTime={post.data.readingTime}
            tags={post.data.tags}
            slug={post.id}
          />
        ))}
      </PostGrid>
    </section>
  </div>
</BaseLayout>

<style>
  .section {
    margin-bottom: 3rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.25rem;
  }

  .section-title {
    margin-bottom: 1.25rem;
  }

  .section-header .section-title {
    margin-bottom: 0;
  }

  .view-all {
    font-size: 0.9375rem;
    font-weight: 500;
  }
</style>
